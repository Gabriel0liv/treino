<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           targetNamespace="http://example.com/service"
           xmlns="http://example.com/service"
           elementFormDefault="qualified">


    <xs:simpleType name="numeroCartaoTipo">
        <xs:restriction base="xs:string">
        <xs:pattern value="[0-9]{8}" />
        </xs:restriction>
    </xs:simpleType>

    <xs:element name="getMembroRequest" >
        <xs:complexType>
            <xs:sequence>
                <xs:element name="numeroCartao" type="numeroCartaoTipo"/>
            </xs:sequence>
        </xs:complexType>
    </xs:element>

    <xs:element name="getMembroResponse">
        <xs:complexType>
            <xs:sequence>
                <xs:element name="nomeSocio" type="xs:string"/>
                <xs:element name="nif" type="xs:string"/>
                <xs:element name="email" type="xs:string"/>
                <xs:element name="plano" type="xs:string"/>
                <xs:element name="dataInicio" type="xs:string"/>
                <xs:element name="estado" type="xs:string"/>
                <xs:element name="numeroCartao" type="numeroCartaoTipo"/>
            </xs:sequence>
        </xs:complexType>
    </xs:element>

</xs:schema>
