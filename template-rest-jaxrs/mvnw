#!/usr/bin/env sh
set -e
MAVEN_VERSION=3.9.9
MAVEN_BASE="$HOME/.m2/wrapper/dists/apache-maven-$MAVEN_VERSION"
MAVEN_HOME="$MAVEN_BASE/apache-maven-$MAVEN_VERSION"
MAVEN_ZIP="$MAVEN_BASE/apache-maven-$MAVEN_VERSION-bin.zip"
MAVEN_URL="https://archive.apache.org/dist/maven/maven-3/$MAVEN_VERSION/binaries/apache-maven-$MAVEN_VERSION-bin.zip"

if [ ! -x "$MAVEN_HOME/bin/mvn" ]; then
  echo "Maven $MAVEN_VERSION não encontrado localmente."
  echo "A descarregar Maven para: $MAVEN_BASE"
  mkdir -p "$MAVEN_BASE"
  if command -v curl >/dev/null 2>&1; then
    curl -L "$MAVEN_URL" -o "$MAVEN_ZIP"
  elif command -v wget >/dev/null 2>&1; then
    wget "$MAVEN_URL" -O "$MAVEN_ZIP"
  else
    echo "Erro: instala curl/wget ou Maven manualmente."
    exit 1
  fi
  unzip -o "$MAVEN_ZIP" -d "$MAVEN_BASE"
fi

exec "$MAVEN_HOME/bin/mvn" "$@"
